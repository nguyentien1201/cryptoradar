# ============================================================
# CryptoRadar VN — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ---- Server ----
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://cryptoradar.vn
API_URL=https://api.cryptoradar.vn

# ---- Database ----
# Railway PostgreSQL / Supabase / Neon
DATABASE_URL=postgresql://user:password@host:5432/cryptoradar

# ---- Redis ----
# Railway Redis / Upstash
REDIS_URL=redis://default:password@host:6379

# ---- Auth ----
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars

# ---- Email (SMTP) ----
# Recommended: Resend (free 3000/month) or SendGrid
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxx
SMTP_FROM=noreply@cryptoradar.vn

# ---- Telegram Bot ----
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ---- Crypto APIs ----
# CoinGecko Demo API (free, register at coingecko.com)
COINGECKO_API_KEY=CG-xxxxxxxxxxxxx

# CryptoPanic (free, register at cryptopanic.com)
CRYPTOPANIC_API_KEY=your-cryptopanic-key

# Whale Alert (free tier: 10 req/min, register at whale-alert.io)
WHALE_ALERT_API_KEY=your-whale-alert-key

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_MONTHLY=price_xxxxx   # Create in Stripe Dashboard: $9.99/month
STRIPE_PRICE_YEARLY=price_xxxxx    # Create in Stripe Dashboard: $89.99/year

# ---- MoMo ----
MOMO_PARTNER_CODE=your-partner-code
MOMO_ACCESS_KEY=your-access-key
MOMO_SECRET_KEY=your-secret-key
